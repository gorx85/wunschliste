# Prevent directory listing
Options -Indexes

# Deny access to PHP include files
<FilesMatch "^(config|database|auth|helpers)\.php$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order deny,allow
        Deny from all
    </IfModule>
</FilesMatch>
